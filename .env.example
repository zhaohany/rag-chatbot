# Optional overrides (local defaults already work)
RAG_APP_NAME=rag-local-api
RAG_APP_VERSION=0.1.0

RAG_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=1
RAG_PROMPT_TEMPLATE_PATH=data/prompts/query_prompt_v3.txt
RAG_FINAL_PROMPT_PATH=data/prompts/final_prompt.txt

# Gemini generation
RAG_GEMINI_MODEL=models/gemini-2.0-flash-lite
RAG_GEMINI_API_KEY=
RAG_GEMINI_TIMEOUT_SECONDS=30
RAG_LLM_MAX_OUTPUT_TOKENS=256
